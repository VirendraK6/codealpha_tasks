import java.util.Scanner;

public class GPA_Calculator {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int numCourses;
        double totalCredits = 0;
        double totalGradePoints = 0;

        System.out.print("Enter number of courses: ");
        numCourses = sc.nextInt();

        // Arrays to store course data
        double[] grades = new double[numCourses];
        double[] credits = new double[numCourses];

        // Input loop
        for (int i = 0; i < numCourses; i++) {
            System.out.println("\nCourse " + (i + 1));

            System.out.print("Enter grade (e.g., 10, 9, 8): ");
            grades[i] = sc.nextDouble();

            System.out.print("Enter credit hours: ");
            credits[i] = sc.nextDouble();

            totalCredits += credits[i];
            totalGradePoints += grades[i] * credits[i];
        }

        // GPA calculation
        double gpa = totalGradePoints / totalCredits;

        // Assuming CGPA = GPA (for one semester)
        double cgpa = gpa;

        // Output
        System.out.println("\n--- Course Details ---");
        for (int i = 0; i < numCourses; i++) {
            System.out.println("Course " + (i + 1) +
                    " -> Grade: " + grades[i] +
                    ", Credits: " + credits[i]);
        }

        System.out.println("\nTotal Credits: " + totalCredits);
        System.out.println("Total Grade Points: " + totalGradePoints);
        System.out.printf("GPA: %.2f\n", gpa);
        System.out.printf("CGPA: %.2f\n", cgpa);

        sc.close();
    }
}
